# Копировать в .env.local (локально) или .env.production на сервере.
# ВСЕ ключи опциональны — если не задать, сайт работает, но часть функций отключается.

# ─── Bitrix24: приём заявок в CRM ─────────────────────────────────
# Создать входящий вебхук:
#   Битрикс24 → CRM → Настройки → Разработчикам → Другое → Входящий вебхук
# Скопировать URL вида: https://<portal>.bitrix24.ru/rest/<userId>/<token>/
# Права для вебхука: crm (минимум).
BITRIX_WEBHOOK_URL=

# (опционально) ID сотрудника, на которого назначать лид.
# Узнать: /rest/<portal>/<token>/user.current.json — поле "ID".
BITRIX_ASSIGNED_BY_ID=

# ─── Telegram: быстрые уведомления о заявках ──────────────────────
# Токен общего бота (@aksystems_sales_bot). Тот же, что использует ваш бот-ассистент.
TELEGRAM_BOT_TOKEN=

# ID админ-чата (группа, куда бот шлёт уведомления о заявках).
# Для группы — с минусом: -1001234567890.
TELEGRAM_CHAT_ID=

# Хотя бы один из каналов (Bitrix24 или Telegram) должен быть настроен.
# Если оба пустые — заявки логируются в stdout.

# ─── Яндекс.Метрика ───────────────────────────────────────────────
# ID счётчика. Грузится только после согласия cookie-баннера.
NEXT_PUBLIC_YM_ID=
