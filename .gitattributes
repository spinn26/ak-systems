# Normalise line endings
* text=auto eol=lf

# Keep LF for shell scripts and unix configs (runs on Linux server)
*.sh        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.webp      binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
